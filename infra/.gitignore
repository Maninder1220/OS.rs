```gitignore
# ============================================================
# Terraform / OpenTofu
# ============================================================

# Local provider plugins, modules, and working-directory data
**/.terraform/**

# Terraform and OpenTofu state files
*.tfstate
*.tfstate.*
*.tfstate.backup

# Temporary state lock information
.terraform.tfstate.lock.info
**/.terraform.tfstate.lock.info

# Variable files may contain passwords, tokens, project IDs,
# database credentials, and other environment-specific values
*.tfvars
*.tfvars.json
*.auto.tfvars
*.auto.tfvars.json

# Allow safe example variable files to be committed
!*.tfvars.example
!*.tfvars.json.example
!terraform.tfvars.example

# Saved execution plans
*.tfplan
*.plan
tfplan
tfplan.*
plan.out

# Terraform crash logs
crash.log
crash.*.log

# Local CLI configuration
.terraformrc
terraform.rc

# Local override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Environment and secret files
.env
.env.*
!.env.example

# Sensitive credential and private-key files
*.pem
*.key
*.p12
*.pfx
credentials.json
service-account.json
service-account-key.json

# Local cache and temporary files
.cache/
tmp/
temp/
*.tmp
*.bak
*.swp
*~

# Operating-system files
.DS_Store
Thumbs.db

# IDE and editor settings
.idea/
.vscode/
*.code-workspace
```
